---
import Base from '../layouts/Base.astro'
import Content from '../components/sections/Content.astro'
import Socials from '../content/socials.astro'
import Faq from '../content/Faq.astro'
import FaqItem from '../content/FaqItem.astro'
import Button from '../components/Button.astro'

import heroImage from '../assets/images/venue/venue.png'

import LucideClock from '~icons/lucide/clock';
import LucideCircleParking from '~icons/lucide/circle-parking';
import LucideUtensils from '~icons/lucide/utensils';
import LucideAccessibility from '~icons/lucide/accessibility';
import LucideWifi from '~icons/lucide/wifi';
import LucideDumbbell from '~icons/lucide/dumbbell';
import LucideCoffee from '~icons/lucide/coffee';
import LucideAirVent from '~icons/lucide/air-vent';
import LucideHandPlatter from '~icons/lucide/hand-platter';
import LucideWine from '~icons/lucide/wine';
import LucideCigaretteOff from '~icons/lucide/cigarette-off';
---

<Base>
  <Content headline="The venue: Mercure hotel Antwerp" sideImage={heroImage} bg="secondary">
    <p>
      This year's hotel is the wonderful Bedford Hotel in Brussels — a cozy base just steps away from the city centre,
      the train station, countless eateries, and the vibrant nightlife.
    </p>
    <Fragment slot="actions">
      <Button label="Contact us" outline go to="/contact" />
      <Button label="Learn more" outline to="/about" />
    </Fragment>
  </Content>
  <Content headline="Room types and comforts" sideImage={heroImage} right>
    <div>
    <p>
      Decorated with warm colours and soft textures, all spacious rooms at Mercure Antwerp City South are fitted with
      king-size bedding. They all include a flat-screen TV while some include access to the Executive Lounge.
    </p>
    </div>
    <p class="flex items-center gap-3 mt-4"><LucideClock></LucideClock>Check-in from 15:00 - Check-out up to 12:00</p>
    <h3 class="text-xl font-bold uppercase mt-8">Amenities on site include:</h3>
    <div class="grid grid-cols-[auto_1fr_auto_1fr] items-center gap-2 mt-4">
      <LucideCircleParking></LucideCircleParking><p>Car park</p>
      <LucideAccessibility></LucideAccessibility><p>Wheelchair accessible</p>
      <LucideUtensils></LucideUtensils><p>Restaurant</p>
      <LucideWifi></LucideWifi><p>WiFi</p>
      <LucideDumbbell></LucideDumbbell><p>Fitness center</p>
      <LucideCoffee></LucideCoffee><p>Breakfast</p>
      <LucideAirVent></LucideAirVent><p>Air conditioning</p>
      <LucideHandPlatter></LucideHandPlatter><p>Room service</p>
      <LucideWine></LucideWine><p>Bar</p>
      <LucideCigaretteOff></LucideCigaretteOff><p>100% non smoking property</p>
    </div>
  </Content>
  <Socials />
  <Faq>
    <FaqItem question="Can I pay in installments?">
      Installment payment is not officially offered. Tickets must be paid in full at registration unless a specific
      arrangement has been made.
    </FaqItem>
    <FaqItem question="Which payment methods do you accept?">
      Payments for registration are handled online and are via bank transfer only. For hotel or food purchases, local
      card and cash payments are accepted at the venue.
    </FaqItem>
  </Faq>
</Base>

<style lang="scss" is:global>
  .content .pricing {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    gap: 22px;
    margin: 48px 0;

    @media (max-width: 1200px) and (min-width: 601px) {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      flex-direction: column;
      align-items: center;

      > :nth-child(odd) {
        justify-self: end;
      }
    }

    @media (max-width: 600px) {
      flex-direction: column;

      .pricing-card {
        width: 100%;
      }
    }
  }

  .content .pricing_details {
    max-width: 480px;
  }
</style>
