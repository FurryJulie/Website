---
interface Props {
  outerClass?: string
  innerClass?: string
}

const { outerClass, innerClass } = Astro.props
---

<section class:list={['px-[80px] py-[60px] flex justify-center text-primary-800', outerClass]}>
  <div class:list={['max-w-6xl grid grid-cols-2 gap-[92px]', innerClass]}>
    <slot name="left" />
    <slot />
    <slot name="right" />
  </div>
</section>
